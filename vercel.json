{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/admin",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet" }
      ]
    },
    {
      "source": "/admin/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet" }
      ]
    },
    {
      "source": "/portal",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet" }
      ]
    },
    {
      "source": "/portal/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet" }
      ]
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/contact.ts": {
      "maxDuration": 30
    },
    "api/portal.ts": {
      "maxDuration": 60
    }
  },
  "redirects": [
    { "source": "/portraits", "destination": "/gallery/portraits", "permanent": true },
    { "source": "/maternity", "destination": "/gallery/maternity", "permanent": true },
    { "source": "/family", "destination": "/gallery/family", "permanent": true },
    { "source": "/weddings", "destination": "/gallery/weddings", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/api/portal/:action",
      "destination": "/api/portal?action=:action"
    },
    {
      "source": "/api/admin/:action",
      "destination": "/api/admin?action=:action"
    },
    {
      "source": "/photo/:category/:photoId",
      "destination": "/photo/:category/:photoId.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
